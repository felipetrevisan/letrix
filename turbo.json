{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "LETRIX_ADMIN_EMAILS",
        "NEXT_PUBLIC_LETRIX_ADMIN_EMAILS",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "outputs": ["apps/web/.next/**", "!apps/web/.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    }
  }
}
